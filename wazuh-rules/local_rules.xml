<!-- 
  Custom Wazuh Detection Rules
  Lab: Sysmon + Wazuh Endpoint Detection
  Mapped to MITRE ATT&CK Framework
-->

<group name="sysmon,">

  <!-- Rule 1: Credential Dumping - lsass access (Mimikatz) -->
  <rule id="100001" level="12">
    <if_group>sysmon_event_10</if_group>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe</field>
    <description>CRITICAL: Credential dumping - process accessing lsass.exe (T1003)</description>
    <mitre>
      <id>T1003</id>
    </mitre>
    <group>credential_dumping,</group>
  </rule>

  <!-- Rule 2: Registry Persistence via Run Key -->
  <rule id="100002" level="10">
    <if_group>sysmon_event_13</if_group>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)CurrentVersion\\Run</field>
    <description>HIGH: Registry persistence via Run key detected (T1547.001)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
    <group>persistence,</group>
  </rule>

  <!-- Rule 3: Suspicious Process from Office Application -->
  <rule id="100003" level="8">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)(cmd\.exe|powershell\.exe|wscript\.exe|cscript\.exe)</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(word\.exe|excel\.exe|outlook\.exe|winword\.exe)</field>
    <description>MEDIUM: Suspicious process spawned from Office application (T1059)</description>
    <mitre>
      <id>T1059</id>
    </mitre>
    <group>execution,</group>
  </rule>

  <!-- Rule 4: Whoami Reconnaissance -->
  <rule id="100004" level="6">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)whoami\.exe</field>
    <description>MEDIUM: Whoami executed - possible post-exploitation recon (T1033)</description>
    <mitre>
      <id>T1033</id>
    </mitre>
    <group>reconnaissance,</group>
  </rule>

  <!-- Rule 5: New Service Creation -->
  <rule id="100005" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)sc\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)create</field>
    <description>HIGH: New service created via sc.exe - possible persistence (T1543)</description>
    <mitre>
      <id>T1543</id>
    </mitre>
    <group>persistence,</group>
  </rule>

  <!-- Rule 6: EICAR Malware Test File Detection -->
  <rule id="100006" level="12">
    <if_group>sysmon_event_11</if_group>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)(eicar|malware|payload|shell)</field>
    <description>CRITICAL: Suspicious file created - possible malware dropped (T1105)</description>
    <mitre>
      <id>T1105</id>
    </mitre>
    <group>malware,</group>
  </rule>

  <!-- Rule 7: Network Connection to suspicious port -->
  <rule id="100007" level="8">
    <if_group>sysmon_event3</if_group>
    <field name="win.eventdata.destinationPort" type="pcre2">^(4444|1337|9999|8888)$</field>
    <description>HIGH: Network connection to common C2 port detected (T1071)</description>
    <mitre>
      <id>T1071</id>
    </mitre>
    <group>command_and_control,</group>
  </rule>

  <!-- Rule 8: PowerShell Encoded Command -->
  <rule id="100008" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-enc|-encodedcommand|-e )</field>
    <description>HIGH: PowerShell encoded command detected - possible obfuscation (T1027)</description>
    <mitre>
      <id>T1027</id>
    </mitre>
    <group>defense_evasion,</group>
  </rule>

</group>
